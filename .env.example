# Application environment (development | production)
PRIMARY__ENV=development

# HTTP server
SERVER__PORT=:8080
SERVER__READ_TIMEOUT=30
SERVER__WRITE_TIMEOUT=30
SERVER__IDLE_TIMEOUT=120
SERVER__CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Cluster
PRIMARY__NAME=node-1                    # this node's identity — hashed onto the ring
PRIMARY__NUMBER=1                       # metadata only
PRIMARY__PEERS=node-1@localhost:8081,node-2@localhost:8082,node-3@localhost:8083  # all nodes as name@host:port (incl. self)
